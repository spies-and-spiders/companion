;; Application configuration. This is the primary way a DM defines loot types
;; and rules — no Clojure required. Secrets (e.g. backup credentials) should be
;; referenced via aero tags reading env vars, never written inline.
{:storage    {#_#_:backend :mysql
              :backend :file
              :url "jdbc:mariadb://localhost:3306/sns"}

 :plugins    [{:type :builtin :id :divine-dust :entrypoint sns.builtin.dust/generator}
              {:type :builtin :id :relics :entrypoint sns.builtin.relics/generator}
              {:type :json :id :uniques :data "data/uniques.edn"}
              {:type :json :id :rings :data "data/rings.edn"}]

 :loot-table [{:id :divine-dust :weight 40}
              {:id :uniques :weight 25}
              {:id :rings :weight 20}
              {:id :relics :weight 15}]}
