{
  "$ref" : "#/definitions/sns.spi.schema~1config",
  "definitions" : {
    "sns.spi.schema/config" : {
      "type" : "object",
      "properties" : {
        "storage" : {
          "$ref" : "#/definitions/sns.spi.schema~1storage"
        },
        "plugins" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/definitions/sns.spi.schema~1plugin"
          }
        },
        "loot-table" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/definitions/sns.spi.schema~1loot-entry"
          }
        }
      },
      "required" : [ "plugins" ]
    },
    "sns.spi.schema/storage" : {
      "type" : "object",
      "properties" : {
        "backend" : {
          "type" : "string"
        },
        "url" : {
          "type" : "string"
        },
        "db" : {
          "type" : "string"
        },
        "git-remote" : {
          "type" : "string"
        }
      },
      "required" : [ "backend" ]
    },
    "sns.spi.schema/plugin" : {
      "oneOf" : [ {
        "type" : "object",
        "properties" : {
          "type" : {
            "const" : "data"
          },
          "id" : {
            "type" : "string"
          },
          "source" : {
            "type" : "string"
          }
        },
        "required" : [ "type", "id", "source" ]
      }, {
        "type" : "object",
        "properties" : {
          "type" : {
            "const" : "cli"
          },
          "id" : {
            "type" : "string"
          },
          "command" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          }
        },
        "required" : [ "type", "id", "command" ]
      }, {
        "type" : "object",
        "properties" : {
          "type" : {
            "const" : "jar"
          },
          "id" : {
            "type" : "string"
          },
          "jar" : {
            "type" : "string"
          },
          "entrypoint" : {
            "type" : "string"
          }
        },
        "required" : [ "type", "id", "jar", "entrypoint" ]
      }, {
        "type" : "object",
        "properties" : {
          "type" : {
            "const" : "builtin"
          },
          "id" : {
            "type" : "string"
          },
          "entrypoint" : {
            "type" : "string"
          }
        },
        "required" : [ "type", "id", "entrypoint" ]
      } ]
    },
    "sns.spi.schema/loot-entry" : {
      "type" : "object",
      "properties" : {
        "id" : {
          "type" : "string"
        },
        "weight" : {
          "type" : "number"
        }
